# Copy to .env and fill in. Bun auto-loads .env; all keys are read server-side only.

# Required: OpenRouter API key (https://openrouter.ai/keys). Set a hard prepaid
# credit cap on your account before exposing this anywhere.
OPENROUTER_API_KEY=

# Web search/fetch and datetime are OpenRouter server tools — no separate search/
# fetch keys needed. They bill OpenRouter credits per use (web_search ~$0.005/call,
# web_fetch ~$1/1k fetches, datetime free).

# Optional: override the default model (any OpenRouter slug).
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# Used later (milestone 6): shared-password gate for the web app.
APP_PASSWORD=
